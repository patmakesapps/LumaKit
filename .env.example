# Add your model of choice:
OLLAMA_MODEL="Your Ollama model here"
OLLAMA_FALLBACK_MODEL="Your Ollama model here"
# If running two cloud models for the main models you can optionally set a local model here
OLLAMA_LOCAL_MODEL="Your Ollama model here"
# Suggested fallback model - local model and/or dedicated image model
# "glm-5:cloud" works insanely well with this repo
# "gemma4:e4b" for fallback + image model

# Recommended to use a cloud model as the primary model unless
# your machine can run a big model locally.

# Smaller downloadable Ollama local models are listed below. 
# NAME                   ID              SIZE      MODIFIED   
phi3:latest            4f2222927938    2.2 GB    8 days ago    
qwen2.5-coder:3b       f72c60cabf62    1.9 GB    8 days ago    
gemma3:4b              a2af6cc3eb7f    3.3 GB    8 days ago    
deepseek-coder:6.7b    ce298d984115    3.8 GB    8 days ago    
qwen2.5:3b             357c53fb659c    1.9 GB    8 days ago    
qwen-agent:latest      8504ac63e41b    986 MB    8 days ago 

# Serp API for premium web search capabilities.
SERPAPI_KEY="Your API key here"

# Telegram bot (create via @BotFather on Telegram)
TELEGRAM_BOT_TOKEN="Your bot token here"
# Comma-separated chat IDs — first is the owner/admin
TELEGRAM_ALLOWED_IDS="your_id,spouse_id,kid_id"

# Lumi's own email account (Gmail recommended — use an App Password)
# Generate one at https://myaccount.google.com/apppasswords
# Email tools are owner-only (only the first TELEGRAM_ALLOWED_IDS can trigger them)
LUMI_EMAIL_ADDRESS=
LUMI_USER_PASSWORD=
LUMI_EMAIL_PASSWORD=
LUMI_EMAIL_SMTP_HOST="smtp.gmail.com"
LUMI_EMAIL_SMTP_PORT="465"
LUMI_EMAIL_IMAP_HOST="imap.gmail.com"
LUMI_EMAIL_IMAP_PORT="993"
# Signature appended to every outbound email
LUMI_EMAIL_SIGNATURE="Lumi - official LumaKit agent"
# Max emails Lumi can send per rolling 1-hour window (safety cap)
LUMI_EMAIL_MAX_PER_HOUR="10"
